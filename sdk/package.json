{
  "name": "dripmetric",
  "version": "2.1.0",
  "description": "Official SDK for Dripmetric — track user onboarding and automate drip emails.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "homepage": "https://www.dripmetric.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshit110927/onboardflow.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "onboarding",
    "drip email",
    "saas",
    "analytics"
  ],
  "author": "Dripmetric",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
